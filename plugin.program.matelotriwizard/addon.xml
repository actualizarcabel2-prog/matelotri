<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.matelotriwizard" name="Matelotri Wizard" version="2.0.0" provider-name="Agustin">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="es_ES">Matelotri Wizard - Tu cine en casa</summary>
        <summary lang="en_GB">Matelotri Wizard - Your home cinema</summary>
        <description lang="es_ES">Centro de control Matelotri. Instala, configura y mantiene tu experiencia cinematografica perfecta.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>
